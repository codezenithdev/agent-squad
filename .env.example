# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values.
# The real ".env" is git-ignored and must NEVER be committed (it holds secrets).
# ---------------------------------------------------------------------------

# --- LLM mode -------------------------------------------------------------
# true  = free, offline, deterministic mock responses (default; great for testing)
# false = real LLM calls (requires the chosen provider's API key below)
USE_MOCK_LLM=true

# --- Provider selection ---------------------------------------------------
# auto      = prefer OpenAI when OPENAI_API_KEY is set, else Anthropic
# openai    = always use OpenAI
# anthropic = always use Anthropic (Claude)
LLM_PROVIDER=auto

# --- API keys (only the chosen provider's key is required) ----------------
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- LangSmith tracing (optional observability) ---------------------------
# Leave tracing off unless you have a LangSmith key.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=multi-agent-architect

# --- Model tiering, per provider (strong = reviewer, worker = everyone else) -
OPENAI_STRONG_MODEL=gpt-4o
OPENAI_WORKER_MODEL=gpt-4o-mini
ANTHROPIC_STRONG_MODEL=claude-sonnet-4-5
ANTHROPIC_WORKER_MODEL=claude-haiku-4-5

# --- Circuit-breaker limit (max Coder<->Tester / Coder<->BugDetector loops) -
MAX_ITERATIONS=3
