# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values.
# The real ".env" is git-ignored and must NEVER be committed (it holds secrets).
# ---------------------------------------------------------------------------

# --- LLM mode -------------------------------------------------------------
# true  = free, offline, deterministic mock responses (default; great for learning)
# false = real OpenAI calls (requires OPENAI_API_KEY below)
USE_MOCK_LLM=true

# --- OpenAI (only needed when USE_MOCK_LLM=false) -------------------------
OPENAI_API_KEY=sk-your-key-here

# --- LangSmith tracing (optional observability) ---------------------------
# Leave tracing off unless you have a LangSmith key.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=multi-agent-architect

# --- Model tiering (GPT-4o for the "thinkers", mini for the workers) ------
SUPERVISOR_MODEL=gpt-4o
REVIEWER_MODEL=gpt-4o
WORKER_MODEL=gpt-4o-mini

# --- Circuit-breaker limit (max Coder<->Tester / Coder<->BugDetector loops) -
MAX_ITERATIONS=3
